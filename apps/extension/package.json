{
  "name": "@openheaders/extension",
  "version": "4.0.0",
  "private": true,
  "description": "OpenHeaders browser extension for Chrome, Firefox, Edge, and Safari",
  "scripts": {
    "build": "pnpm run build:chrome && pnpm run build:firefox && pnpm run build:edge && pnpm run build:safari",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "build:safari": "BROWSER=safari vite build",
    "dev": "BROWSER=chrome vite build --watch",
    "dev:chrome": "BROWSER=chrome vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "dev:edge": "BROWSER=edge vite build --watch",
    "dev:safari": "BROWSER=safari vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "typecheck": "tsc --noEmit",
    "postbuild": "npx tsx config/scripts/build-report.ts",
    "release": "npx tsx config/scripts/release.ts",
    "source-zip": "npx tsx config/scripts/source-zip.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openheaders/core": "workspace:*",
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rrweb": "^2.0.0-alpha.18",
    "rrweb-player": "^2.0.0-alpha.18",
    "styled-components": "^6.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^5.3.2",
    "jsdom": "^29.0.1",
    "less": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "qs": "^6.14.1",
    "node-forge": "^1.3.2",
    "lodash": "^4.17.23"
  }
}
