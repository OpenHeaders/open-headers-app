{
  "name": "@openheaders/desktop",
  "version": "4.1.0",
  "private": true,
  "description": "OpenHeaders desktop app",
  "main": "dist-webpack/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron-vite dev",
    "build": "cross-env NODE_ENV=production electron-vite build",
    "build:dev": "cross-env NODE_ENV=development electron-vite build",
    "predist": "pnpm run build",
    "dist": "electron-builder --publish never",
    "dist:all": "pnpm run predist && electron-builder -mwl --x64 --arm64 --publish never",
    "dist:mac": "pnpm run predist && electron-builder --mac --publish never",
    "dist:mac:unsigned": "pnpm run predist && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "dist:mac:unsigned:arm64": "pnpm run predist && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --config.mac.target=dmg --publish never",
    "dist:win": "pnpm run predist:win && electron-builder --win --publish never",
    "dist:win:unsigned": "pnpm run predist:win && cross-env WIN_CSC_LINK='' electron-builder --win --publish never",
    "dist:linux": "pnpm run predist && electron-builder --linux --x64 --arm64 --publish never",
    "dist:linux:rpm:x64": "pnpm run predist && electron-builder --linux --x64 --config.linux.target=rpm --publish never",
    "dist:linux:rpm:arm64": "pnpm run predist && electron-builder --linux --arm64 --config.linux.target=rpm --publish never",
    "predist:win": "pnpm run build && pnpm run download-portable-git && pnpm run build:minimal-git",
    "download-portable-git": "node scripts/build/download-portable-git.js",
    "build:minimal-git": "node scripts/build/build-minimal-git.js",
    "build:dmg-bg": "node scripts/build/build-dmg-background.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:headed": "pnpm exec playwright test --headed",
    "typecheck": "tsc --noEmit && tsc -p src/renderer/tsconfig.json --noEmit",
    "clean": "rm -rf dist-webpack dist .electron-vite"
  },
  "build": {
    "appId": "io.openheaders",
    "productName": "OpenHeaders",
    "protocols": [
      {
        "name": "OpenHeaders Protocol",
        "schemes": [
          "openheaders"
        ]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "dist-webpack/**/*"
    ],
    "asar": true,
    "compression": "maximum",
    "afterSign": "./scripts/build/notarize.js",
    "afterPack": "./scripts/build/afterPackHook.js",
    "extraResources": [
      {
        "from": "dev-app-update.yml",
        "to": "app-update.yml"
      },
      {
        "from": "build",
        "to": ".",
        "filter": [
          "*.png",
          "*.ico",
          "*.svg"
        ]
      },
      {
        "from": "src/renderer/images",
        "to": "images",
        "filter": [
          "*.png"
        ]
      }
    ],
    "asarUnpack": [
      "dist-webpack/renderer/images/**/*",
      "node_modules/@openheaders/windows-foreground/**/*",
      "node_modules/@openheaders/**/*"
    ],
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "nativeRebuilder": "sequential",
    "includeSubNodeModules": false,
    "extends": null,
    "removePackageScripts": true,
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "include": "build/windows/installer.nsh",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "OpenHeaders ${version}",
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    },
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "icon": "build/icon.ico",
      "forceCodeSigning": false,
      "extraResources": [
        {
          "from": "build/windows/portable/MinimalGit",
          "to": "git",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/mac/entitlements.mac.plist",
      "entitlementsInherit": "build/mac/entitlements.mac.plist",
      "type": "distribution",
      "notarize": false,
      "forceCodeSigning": false,
      "darkModeSupport": true,
      "extendInfo": {
        "CFBundleDisplayName": "OpenHeaders",
        "CFBundleName": "OpenHeaders",
        "CFBundleIdentifier": "io.openheaders",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "OpenHeaders Protocol",
            "CFBundleURLSchemes": [
              "openheaders"
            ]
          }
        ]
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility;Development;Network",
      "executableName": "open-headers",
      "maintainer": "Daniel Tirzuman <github@tirzuman.com>",
      "desktop": {
        "Name": "OpenHeaders",
        "Comment": "OpenHeaders",
        "Terminal": false,
        "Categories": "Utility;Development;Network",
        "MimeType": "x-scheme-handler/openheaders"
      },
      "synopsis": "Record your browser workflow. Modify HTTP Traffic. Team Workspaces. Everything local.",
      "description": "Record your browser workflow. Modify HTTP Traffic. Team Workspaces. Everything local."
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ],
      "fpm": [
        "--deb-recommends=libgtk-3-0",
        "--deb-recommends=libnotify4",
        "--deb-recommends=libnss3",
        "--deb-recommends=libxss1",
        "--deb-recommends=libxtst6",
        "--deb-recommends=xdg-utils",
        "--deb-recommends=libatspi2.0-0",
        "--deb-recommends=libuuid1",
        "--deb-recommends=libsecret-1-0"
      ],
      "artifactName": "${name}_${version}_${arch}.${ext}",
      "compression": "xz",
      "priority": "optional",
      "afterInstall": "./scripts/debian/postinst"
    },
    "rpm": {
      "artifactName": "${name}-${version}.${arch}.rpm",
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-core",
        "libuuid",
        "libsecret"
      ],
      "fpm": [
        "--rpm-rpmbuild-define=_build_id_links none",
        "--rpm-os=linux",
        "--rpm-rpmbuild-define=_binary_payload w2.xzdio",
        "--rpm-rpmbuild-define=_binary_filedigest_algorithm 2",
        "--rpm-rpmbuild-define=_source_filedigest_algorithm 2"
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "desktop": {
        "Name": "OpenHeaders",
        "Comment": "OpenHeaders",
        "Categories": "Utility;Development;Network"
      }
    },
    "dmg": {
      "format": "ULFO",
      "writeUpdateInfo": false,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 135,
          "y": 220
        },
        {
          "x": 405,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "OpenHeaders",
      "repo": "open-headers-app"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@openheaders/core": "workspace:*",
    "adm-zip": "^0.5.16",
    "antd": "^6.3.5",
    "auto-launch": "^5.0.6",
    "chokidar": "^3.5.3",
    "dayjs": "^1.11.20",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.6.2",
    "glob": "^13.0.6",
    "http-proxy": "^1.18.1",
    "node-abi": "^4.26.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^1.8.11",
    "react-window-infinite-loader": "^1.0.10",
    "rrweb": "^2.0.0-alpha.14",
    "rrweb-player": "^2.0.0-alpha.14",
    "scheduler": "^0.27.0",
    "tar": "^7.5.4",
    "valibot": "^1.3.1",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "@openheaders/windows-foreground": "^1.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@octokit/rest": "^21.1.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^20.19.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/ws": "^8.18.1",
    "bufferutil": "^4.0.8",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.0",
    "less": "^4.2.0",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^5.9.3",
    "utf-8-validate": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "node-abi": "^4.26.0",
    "lodash": "^4.17.23",
    "tar": "^7.5.4"
  }
}
